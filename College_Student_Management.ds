	reports
	{
		list attendance_Report
		{
			displayName = "All Attendances"
			show all rows from attendance    
			(
				student as "Student"
				faculty as "Faculty"
				course as "Course"
				date_1 as "Date"
				status as "Status"
				attendance_percentage as "Attendance Percentage"
				(
					display = total,average,min,max	
				)
			)
		}
		list marks_Report
		{
			displayName = "All Marks"
			show all rows from marks    
			(
				student as "Student"
				course as "Course"
				internal_marks as "Internal Marks"
				external_marks as "External Marks"
				total as "Total"
				grade as "Grade"
				result_status as "Result Status"
			)
		}
		kanban marks_by_grade
		{
			displayName = "Grades"
			show all rows from marks    
			(
				student as "Student"
				course as "Course"
				internal_marks as "Internal Marks"
				external_marks as "External Marks"
				total as "Total"
				grade as "Grade"
				result_status as "Result Status"
			)
			options
			(
	 			display field = grade
	 		)
		}
		list students_Report
		{
			displayName = "All Students"
			show all rows from students    
			(
				student_id as "Student ID"
				full_name  as "Full Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				date_of_birth as "Date of Birth"
				gender as "Gender"
				email as "Email"
				phone_number as "Phone Number"
				address  as "Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				course as "Course"
				year_semester as "Year/Semester"
				admission_date as "Admission Date"
				document_upload as "Document Upload"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (gender == "Female")
				fields = [gender]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (gender == "Male")
				fields = [gender]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban students_by_gender
		{
			displayName = "Genders"
			show all rows from students    
			(
				student_id as "Student ID"
				full_name  as "Full Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				date_of_birth as "Date of Birth"
				gender as "Gender"
				email as "Email"
				phone_number as "Phone Number"
				address  as "Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				course as "Course"
				year_semester as "Year/Semester"
				admission_date as "Admission Date"
				document_upload as "Document Upload"
			)
			options
			(
	 			display field = gender
	 		)
		}
		list faculty_Report
		{
			displayName = "All Faculties"
			show all rows from faculty    
			(
				faculty_id as "Faculty ID"
				name  as "Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				department as "Department"
				email as "Email"
				phone_number as "Phone Number"
				subject_assigned as "Subject Assigned"
			)
		}
		list dashboard_Report
		{
			displayName = "All Dashboards"
			show all rows from dashboard    
			(
				students_per_course as "Students Per Course"
				attendance_summary as "Attendance Summary"
				pass_percentage as "Pass Percentage"
				(
					display = total,average,min,max	
				)
				fail_percentage as "Fail Percentage"
				(
					display = total,average,min,max	
				)
			)
		}
		list user_roles_Report
		{
			displayName = "All User Roles"
			show all rows from user_roles    
			(
				user as "User"
				role as "Role"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (role == "Admin")
				fields = [role]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (role == "Student")
				fields = [role]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban user_roles_by_role
		{
			displayName = "Roles"
			show all rows from user_roles    
			(
				user as "User"
				role as "Role"
			)
			options
			(
	 			display field = role
	 		)
		}
		list zoho_people_department_Report
		{
			displayName = "Zoho People Department Report"
			show all rows from zoho_people_department    
			(
				department_name as "Department Name"
				mail_alias as "Mail Alias"
			)
		}
		list zoho_people_employee_Report
		{
			displayName = "Zoho People Employee Report"
			show all rows from zoho_people_employee    
			(
				about_me as "About Me"
				date_of_birth as "Date of Birth"
				date_of_exit as "Date of Exit"
				date_of_joining as "Date of Joining"
				email_address as "Email address"
				employment_type as "Employment Type"
				employee_id as "Employee ID"
				employee_status as "Employee Status"
				ask_me_about_expertise as "Ask me about/Expertise"
				extension as "Extension"
				first_name1 as "First Name"
				gender as "Gender"
				last_name1 as "Last Name"
				marital_status as "Marital Status"
				personal_mobile_number as "Personal Mobile Number"
				preferred_name as "Preferred Name"
				personal_email_address as "Personal Email Address"
				single_line_1 as "Single Line 1"
				social_security_system_joined_date as "Social Security System Joined Date"
				source_of_hire as "Source of Hire"
				tags as "Tags"
				seating_location as "Seating Location"
				work_phone_number as "Work Phone Number"
			)
		}
